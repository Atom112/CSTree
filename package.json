{
  "name": "cstree",
  "version": "0.1.0",
  "private": true,
  "description": "CS Knowledge Tree — 自底向上学习计算机科学",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate && astro build && npm run pagefind && npm run sitemap",
    "validate": "npx tsx src/scripts/validate-graph.ts",
    "pagefind": "npx pagefind --site dist --output-subdir _pagefind",
    "sitemap": "npx tsx src/scripts/generate-sitemap.ts",
    "preview": "npm run build && wrangler dev",
    "check": "astro check",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "11",
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/mdx": "^3.1.0",
    "@astrojs/react": "^3.6.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^5.1.0",
    "@pagefind/default-ui": "^1.5.2",
    "@types/d3": "^7.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "d3": "^7.9.0",
    "katex": "^0.17.0",
    "mdast-util-to-string": "^4.0.0",
    "pagefind": "^1.5.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "remark-parse": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "unified": "^11.0.0",
    "wrangler": "^4.99.0"
  }
}
