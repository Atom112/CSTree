---
// SelectionSearch — 选中文本后的浮动工具栏
// 仅在知识节点内容页生效 (.knowledge-content 区域内)
// 提供：复制、搜索网络、知识库搜索 三个操作
---

<style is:global>
  /* ── Selection toolbar ── */
  .sel-popup {
    position: fixed;
    z-index: 9999;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    padding: 4px;
    display: none;
    pointer-events: auto;
    user-select: none;
    align-items: stretch;
    gap: 0;
    transition: opacity 0.15s, transform 0.15s;
    opacity: 0;
    transform: translateY(4px);
  }
  .sel-popup.visible {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }
  .dark .sel-popup {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 4px 16px rgba(0,0,0,0.5);
  }

  /* ── Toolbar button ── */
  .sel-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    color: #1e293b;
    transition: background 0.12s;
    white-space: nowrap;
  }
  .sel-btn:hover { background: #f1f5f9; }
  .sel-btn:active { transform: scale(0.96); }
  .dark .sel-btn { color: #e2e8f0; }
  .dark .sel-btn:hover { background: #334155; }
  .sel-btn-svg { width: 15px; height: 15px; flex-shrink: 0; }
  .sel-btn-label { font-size: 12px; font-weight: 500; line-height: 1; }
  .sel-btn-svg-check { display: none; }
  .sel-btn.copied .sel-btn-svg-default { display: none; }
  .sel-btn.copied .sel-btn-svg-check { display: block; }

  /* ── Separator ── */
  .sel-sep {
    width: 1px;
    margin: 6px 2px;
    background: #e2e8f0;
    flex-shrink: 0;
  }
  .dark .sel-sep { background: #334155; }

  /* ── Floating results panel (unchanged) ── */
  .sel-results {
    position: fixed;
    z-index: 9998;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    display: none;
    pointer-events: auto;
    width: 420px;
    max-width: calc(100vw - 32px);
    max-height: min(480px, 60vh);
    overflow-y: auto;
    animation: sel-pop-in 0.18s ease-out;
  }
  .sel-results.visible { display: block; }
  @keyframes sel-pop-in {
    from { transform: translateY(8px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .dark .sel-results {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
  }
  .sel-results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 14px 16px 10px;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    background: inherit;
    border-radius: 12px 12px 0 0;
    z-index: 1;
  }
  .dark .sel-results-header { border-bottom-color: #334155; }
  .sel-results-title {
    font-size: 13px;
    font-weight: 600;
    color: #475569;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  .dark .sel-results-title { color: #94a3b8; }
  .sel-results-query { color: #1e293b; font-weight: 700; }
  .dark .sel-results-query { color: #f1f5f9; }
  .sel-results-close {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: #94a3b8;
    padding: 0 2px;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .sel-results-close:hover { color: #475569; }
  .dark .sel-results-close:hover { color: #cbd5e1; }
  .sel-results-body { padding: 8px 12px 12px; }

  /* ── Mini search result card ── */
  .sel-result {
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 4px;
    transition: background 0.12s;
    cursor: pointer;
  }
  .sel-result:hover { background: #f8fafc; }
  .dark .sel-result:hover { background: #0f172a; }
  .sel-result:last-child { margin-bottom: 0; }
  .sel-result-title { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .sel-result-title a {
    color: #2563eb;
    text-decoration: none;
  }
  .sel-result-title a:hover { text-decoration: underline; }
  .dark .sel-result-title a { color: #60a5fa; }
  .sel-result-excerpt {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dark .sel-result-excerpt { color: #94a3b8; }
  .sel-result-excerpt mark {
    background: #fef08a;
    padding: 0 1px;
    border-radius: 1px;
  }
  .dark .sel-result-excerpt mark {
    background: rgba(113, 63, 18, 0.5);
    color: #fbbf24;
  }

  .sel-loading {
    text-align: center;
    padding: 32px 16px;
    color: #94a3b8;
    font-size: 13px;
  }
  .sel-loading::after {
    content: '';
    display: inline-block;
    width: 16px;
    height: 16px;
    margin-left: 6px;
    border: 2px solid #e2e8f0;
    border-top-color: #3b82f6;
    border-radius: 50%;
    animation: sel-spin 0.6s linear infinite;
    vertical-align: middle;
  }
  .dark .sel-loading::after {
    border-color: #334155;
    border-top-color: #60a5fa;
  }
  @keyframes sel-spin { to { transform: rotate(360deg); } }
  .sel-empty {
    text-align: center;
    padding: 32px 16px;
    color: #94a3b8;
    font-size: 13px;
  }
  .sel-error { text-align: center; padding: 24px 16px; color: #ef4444; font-size: 13px; }
  .sel-error-hint { margin-top: 6px; font-size: 12px; color: #94a3b8; }
  .sel-error-hint a { color: #2563eb; text-decoration: underline; }
  .dark .sel-error-hint a { color: #60a5fa; }
</style>

<script>
(function () {
  'use strict';

  // ── Bail if not on a node page ──
  if (!document.querySelector('.knowledge-content')) return;

  /* ==================================================================
     SVG icons (inlined to avoid external dependencies)
     ================================================================== */
  var ICONS = {
    copy:
      '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
    check:
      '<polyline points="20 6 9 17 4 12"/>',
    globe:
      '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    search:
      '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  };

  function svg(path, cls) {
    return '<svg class="' + cls + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + path + '</svg>';
  }

  /* ==================================================================
     Create toolbar popup
     ================================================================== */
  var popup = document.createElement('div');
  popup.className = 'sel-popup';
  popup.innerHTML =
    '<div class="sel-btn" data-action="copy">' +
      svg(ICONS.copy, 'sel-btn-svg sel-btn-svg-default') +
      svg(ICONS.check, 'sel-btn-svg sel-btn-svg-check') +
      '<span class="sel-btn-label">复制</span>' +
    '</div>' +
    '<div class="sel-sep"></div>' +
    '<div class="sel-btn" data-action="websearch">' +
      svg(ICONS.globe, 'sel-btn-svg') +
      '<span class="sel-btn-label">搜索网络</span>' +
    '</div>' +
    '<div class="sel-sep"></div>' +
    '<div class="sel-btn" data-action="kbsearch">' +
      svg(ICONS.search, 'sel-btn-svg') +
      '<span class="sel-btn-label">知识库搜索</span>' +
    '</div>';
  document.body.appendChild(popup);

  /* ==================================================================
     Create results panel (same as before)
     ================================================================== */
  var panel = document.createElement('div');
  panel.className = 'sel-results';
  panel.innerHTML =
    '<div class="sel-results-header">' +
    '  <div class="sel-results-title">在知识库中搜索 <span class="sel-results-query"></span></div>' +
    '  <button class="sel-results-close">&times;</button>' +
    '</div>' +
    '<div class="sel-results-body"></div>';
  document.body.appendChild(panel);

  var panelQuery = panel.querySelector('.sel-results-query');
  var panelBody = panel.querySelector('.sel-results-body');
  var panelClose = panel.querySelector('.sel-results-close');

  /* ==================================================================
     State
     ================================================================== */
  var selectedText = '';
  var selectionRect = null;
  var popupTimer = null;
  var nodeIndex = null;

  /* ==================================================================
     Popup positioning
     ================================================================== */
  function showPopup(rect) {
    var popupH = 42;
    var gap = 8;

    var top = rect.top - popupH - gap;
    if (top < gap) {
      top = rect.bottom + gap;
    }

    // Estimate popup width ~280px, center over selection
    var popupW = 280;
    var left = rect.left + (rect.width / 2) - (popupW / 2);
    left = Math.max(gap, Math.min(left, window.innerWidth - popupW - gap));

    popup.style.left = left + 'px';
    popup.style.top = top + 'px';
    popup.classList.add('visible');
  }

  function hidePopup() {
    popup.classList.remove('visible');
  }

  /* ==================================================================
     Panel positioning
     ================================================================== */
  function showPanel(rect) {
    var panelW = 420;
    var panelH = Math.min(480, window.innerHeight * 0.6);
    var gap = 10;

    var left = rect.left + (rect.width / 2) - (panelW / 2);
    left = Math.max(8, Math.min(left, window.innerWidth - panelW - 8));

    var below = rect.bottom + gap;
    var above = rect.top - panelH - gap;
    var top;
    if (below + panelH <= window.innerHeight) {
      top = below;
    } else if (above >= 0) {
      top = above;
    } else {
      top = Math.max(8, (window.innerHeight - panelH) / 2);
    }

    panel.style.left = left + 'px';
    panel.style.top = top + 'px';
    panel.classList.add('visible');
  }

  function hidePanel() {
    panel.classList.remove('visible');
    panelBody.innerHTML = '';
  }

  /* ==================================================================
     Actions
     ================================================================== */

  // ── Copy to clipboard ──
  function doCopy(text, btn) {
    if (!text) return;
    (navigator.clipboard ? navigator.clipboard.writeText(text) : Promise.reject())
      .catch(function () {
        // Fallback for older browsers
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      });
    // Flash "copied" feedback
    btn.classList.add('copied');
    setTimeout(function () { btn.classList.remove('copied'); }, 1200);
    hidePopup();
  }

  // ── Search web ──
  function doWebSearch(text) {
    if (!text) return;
    var url = 'https://www.google.com/search?q=' + encodeURIComponent(text);
    window.open(url, '_blank', 'noopener');
    hidePopup();
  }

  // ── Search knowledge base ──
  async function doKBSearch(text, rect) {
    if (!text || !rect) return;
    hidePopup();
    panelBody.innerHTML = '<div class="sel-loading">正在搜索</div>';
    panelQuery.textContent = text;
    showPanel(rect);

    var idx = await loadNodeIndex();
    var results = searchNodes(idx, text);
    renderResults(results, text);
  }

  /* ==================================================================
     Event handlers
     ================================================================== */

  // ── Selection detection ──
  document.addEventListener('mouseup', function (e) {
    if (popupTimer) clearTimeout(popupTimer);

    if (popup.contains(e.target) || panel.contains(e.target)) return;

    if (panel.classList.contains('visible') && !panel.contains(e.target)) {
      hidePanel();
    }

    popupTimer = setTimeout(function () {
      var sel = window.getSelection();
      var text = (sel && sel.toString().trim()) || '';

      if (text.length === 0 || text.length > 300) {
        hidePopup();
        return;
      }

      var node = sel.anchorNode;
      if (!node) { hidePopup(); return; }
      var el = node.nodeType === 3 ? node.parentElement : node;
      if (!el || !el.closest('.knowledge-content')) {
        hidePopup();
        return;
      }

      try {
        var range = sel.getRangeAt(0);
        var rect = range.getBoundingClientRect();
        if (rect.width === 0 && rect.height === 0) { hidePopup(); return; }
        selectionRect = rect;
        selectedText = text;
        showPopup(rect);
      } catch (_) {
        hidePopup();
      }
    }, 20);
  });

  // ── Toolbar button clicks ──
  popup.addEventListener('click', function (e) {
    var btn = e.target.closest('.sel-btn');
    if (!btn) return;
    var action = btn.dataset.action;
    var text = selectedText;
    var rect = selectionRect;
    if (!text) return;

    if (action === 'copy') {
      doCopy(text, btn);
    } else if (action === 'websearch') {
      doWebSearch(text);
    } else if (action === 'kbsearch') {
      doKBSearch(text, rect);
    }
  });

  // ── Hide selection popup on scroll (panel stays) ──
  document.addEventListener('scroll', function () {
    if (popup.classList.contains('visible')) hidePopup();
  }, true);

  document.addEventListener('mousedown', function (e) {
    if (popup.classList.contains('visible') && !popup.contains(e.target) && !panel.contains(e.target)) {
      hidePopup();
    }
    if (panel.classList.contains('visible') && !panel.contains(e.target) && !popup.contains(e.target)) {
      hidePanel();
    }
  });

  // ── Panel close ──
  panelClose.addEventListener('click', hidePanel);

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (panel.classList.contains('visible')) hidePanel();
      else if (popup.classList.contains('visible')) hidePopup();
    }
  });

  // ── Intercept browser's default context menu when our toolbar is showing ──
  document.addEventListener('contextmenu', function (e) {
    if (popup.classList.contains('visible')) {
      e.preventDefault();
    }
  }, true);

  /* ==================================================================
     Node index search (unchanged)
     ================================================================== */
  async function loadNodeIndex() {
    if (nodeIndex) return nodeIndex;
    try {
      var resp = await fetch('/node-index.json');
      nodeIndex = await resp.json();
      return nodeIndex;
    } catch (_) {
      return [];
    }
  }

  function renderResults(results, query) {
    if (!results || results.length === 0) {
      panelBody.innerHTML =
        '<div class="sel-empty">未找到匹配结果</div>' +
        '<div class="sel-error-hint" style="text-align:center">' +
        '前往 <a href="/search?tag=' + encodeURIComponent(query) + '">搜索页</a> 查看更多</div>';
      return;
    }
    var qLow = query.toLowerCase();
    var html = '';
    for (var i = 0; i < results.length; i++) {
      var r = results[i];
      var excerpt = r.summary;
      var exIdx = r.summary.toLowerCase().indexOf(qLow);
      if (exIdx >= 0) {
        excerpt = esc(r.summary.substring(0, exIdx)) +
          '<mark>' + esc(r.summary.substring(exIdx, exIdx + query.length)) + '</mark>' +
          esc(r.summary.substring(exIdx + query.length));
      } else {
        excerpt = esc(r.summary);
      }
      html += '<div class="sel-result" data-href="' + r.url + '">' +
        '<div class="sel-result-title"><a href="' + r.url + '">' + esc(r.title) + '</a></div>' +
        '<div class="sel-result-excerpt">' + excerpt + '</div>' +
        '</div>';
    }
    panelBody.innerHTML = html;
    panelBody.querySelectorAll('.sel-result').forEach(function (card) {
      card.addEventListener('click', function () {
        window.location.href = card.dataset.href;
      });
    });
  }

  function searchNodes(nodes, query) {
    var q = query.toLowerCase();
    var hits = [];
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.title.toLowerCase().indexOf(q) >= 0 || n.summary.toLowerCase().indexOf(q) >= 0) {
        hits.push({
          url: '/node/' + n.id + '/',
          title: n.title,
          summary: n.summary,
        });
      }
    }
    hits.sort(function (a, b) {
      var aT = a.title.toLowerCase().indexOf(q) >= 0 ? 0 : 1;
      var bT = b.title.toLowerCase().indexOf(q) >= 0 ? 0 : 1;
      return aT - bT;
    });
    return hits;
  }

  function esc(str) {
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }
})();
</script>
