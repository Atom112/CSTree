            'placeholder="sk-..." value="' + inputVal + '" />' +
      errorHtml +
      '  <div class="ai-config-row">' +
      '    <button class="ai-config-btn ai-config-btn-primary" id="ai-key-save">保存</button>' +
      '    <button class="ai-config-btn ai-config-btn-secondary" id="ai-key-clear">清除</button>' +
      '    <span style="flex:1"></span>' +
      '    <button class="ai-config-btn ai-config-btn-secondary" id="ai-local-fallback">离线模式</button>' +
      '  </div>' +
      statusHtml +
      '  <div class="ai-model-section">' +
      '    <div class="ai-model-section-title">🧠 选择模型</div>' +
      '    <div class="ai-model-opts" id="ai-model-opts">' + modelOptsHtml + '</div>' +
      '  </div>' +
      '  <div class="ai-config-hint">' +
      '    <strong>📌 ' + (hasBuiltin ? '使用自己的 API Key（可选）' : '如何获取 API Key？') + '</strong><br>' +
      '    1. 访问 <a href="https://cloud.siliconflow.cn" target="_blank">cloud.siliconflow.cn</a> 注册账号<br>' +
      '    2. 进入「API 密钥」页面 → 创建 API Key<br>' +
      '    3. 复制密钥并粘贴到上方输入框<br>' +
      '    4. 点击「保存」<br><br>' +
      '    💡 默认使用 Qwen3-8B 模型，9B 以下永久免费<br>' +
      '    🔒 API Key 仅存储在本地浏览器中' +
      '  </div>' +
      '</div>';

    showPanel(rect);

    var input = document.getElementById('ai-key-input');
    var saveBtn = document.getElementById('ai-key-save');
