  /* ==================================================================
     RAG — build context from node-index.json
     ================================================================== */
  function buildRAGContext(text) {
    if (!nodeIndex) return '';
    var hits = searchNodes(nodeIndex, text);
    if (hits.length === 0) return '';
    return hits.slice(0, 4).map(function (n) {
      return '【' + n.title + '】' + n.summary;
    }).join('\n\n');
  }

  /* ==================================================================
     Simple markdown renderer (safe, basic)
     ================================================================== */
  function renderMarkdown(text) {
    var html = esc(text);
    // Code blocks (```...```)
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, function (_, lang, code) {
      return '<pre><code>' + esc(code.trim()) + '</code></pre>';
    });
    // Inline code (`...`)
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');
    // Bold (**...**)
    html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Italic (*...*)
    html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
    // Links [text](url)
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
    // Line breaks → paragraphs
    html = '<p>' + html.replace(/\n\n+/g, '</p><p>').replace(/\n/g, '<br>') + '</p>';
    return html;
  }

  /* ==================================================================
     AI sources display
     ================================================================== */
  function showAISources(context) {
    if (!context) return;
    var sources = context.split('\n\n').filter(function (s) { return s.trim(); });
    if (sources.length === 0) return;

    var titleMatch, sourceLinks = [];
    for (var i = 0; i < sources.length; i++) {
      titleMatch = sources[i].match(/^【(.+?)】/);
      if (titleMatch) {
        sourceLinks.push(titleMatch[1]);
      }
    }
    if (sourceLinks.length === 0) return;

    // Find actual node data for link URLs
    var hits = [];
    for (var j = 0; j < sourceLinks.length; j++) {
      for (var k = 0; k < (nodeIndex || []).length; k++) {
        if (nodeIndex[k].title === sourceLinks[j]) {
          hits.push(nodeIndex[k]);
          break;
        }
      }
    }

    var html = '<div class="ai-sources">' +
      '<div class="ai-sources-title">📖 参考来源</div>';
    for (var h = 0; h < hits.length; h++) {
      html += '<a class="ai-source-link" href="/node/' + hits[h].id + '/" target="_blank">' +
        svg(ICONS.book, '') + ' ' + esc(hits[h].title) + '</a>';
    }
    html += '</div>';

    var bd = panel.querySelector('.sel-panel-bd');
    bd.insertAdjacentHTML('beforeend', html);
  }

  /* ==================================================================
     Utility: format file size
     ================================================================== */
  function formatSize(bytes) {
    if (bytes < 1024) return bytes + 'B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + 'KB';
    return (bytes / (1024 * 1024)).toFixed(1) + 'MB';
  }

  /* ==================================================================
     Event handlers
     ================================================================== */

  // ── Selection detection ──
  document.addEventListener('mouseup', function (e) {
    if (popupTimer) clearTimeout(popupTimer);

    // Prevent browser's native selection toolbar (Edge/Chrome)
    // when text is selected inside the knowledge content area.
    // This must run synchronously (not in setTimeout) to be effective.
    (function () {
      var s = window.getSelection();
      var t = (s && s.toString().trim()) || '';
      if (t.length === 0 || t.length > 300) return;
      var n = s.anchorNode;
      if (!n) return;
      var el = n.nodeType === 3 ? n.parentElement : n;
      if (el && el.closest('.knowledge-content')) {
        e.preventDefault();
      }
    })();

    if (popup.contains(e.target) || panel.contains(e.target)) return;
    if (panel.classList.contains('visible') && !panel.contains(e.target)) {
      hidePanel();
    }
    popupTimer = setTimeout(function () {
      var sel = window.getSelection();
      var text = (sel && sel.toString().trim()) || '';
      if (text.length === 0 || text.length > 300) { hidePopup(); return; }
      var node = sel.anchorNode;
      if (!node) { hidePopup(); return; }
      var el = node.nodeType === 3 ? node.parentElement : node;
      if (!el || !el.closest('.knowledge-content')) { hidePopup(); return; }
      try {
        var range = sel.getRangeAt(0);
        var rect = range.getBoundingClientRect();
        if (rect.width === 0 && rect.height === 0) { hidePopup(); return; }
        selectionRect = rect;
        selectedText = text;
        showPopup(rect);
      } catch (_) { hidePopup(); }
    }, 20);
  });

  // ── Toolbar button clicks ──
  popup.addEventListener('click', function (e) {
    var btn = e.target.closest('.sel-btn');
    if (!btn) return;
    var action = btn.dataset.action;
    var text = selectedText;
    var rect = selectionRect;
    if (!text) return;

    if (action === 'copy') {
      doCopy(text, btn);
    } else if (action === 'websearch') {
      doWebSearch(text);
    } else if (action === 'kbsearch') {
      doKBSearch(text, rect);
    } else if (action === 'aiask') {
      doAskAI(text, rect);
    }
  });

  // ── Scroll / mousedown / keydown ──
  document.addEventListener('scroll', function () {
    if (popup.classList.contains('visible')) hidePopup();
  }, true);

  document.addEventListener('mousedown', function (e) {
    if (popup.classList.contains('visible') && !popup.contains(e.target) && !panel.contains(e.target)) {
      hidePopup();
    }
    if (panel.classList.contains('visible') && !panel.contains(e.target) && !popup.contains(e.target)) {
      hidePanel();
    }
  });

  panelClose.addEventListener('click', hidePanel);

  panelConfig.addEventListener('click', function () {
    if (activeMode === 'ai') {
      var text = selectedText || panelTitle.textContent.replace(/^.*?/, '');
      showAIConfig(text, { left: parseInt(panel.style.left) || 0, top: parseInt(panel.style.top) || 0 });
    }
  });

  panelRefresh.addEventListener('click', function () {
    if (activeMode === 'ai' && selectedText && selectionRect) {
      doAskAI(selectedText, selectionRect);
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (panel.classList.contains('visible')) hidePanel();
      else if (popup.classList.contains('visible')) hidePopup();
    }
  });

  document.addEventListener('contextmenu', function (e) {
    if (popup.classList.contains('visible')) e.preventDefault();
  }, true);

  /* ==================================================================
     Node index utilities
     ================================================================== */
  async function loadNodeIndex() {
    if (nodeIndex) return nodeIndex;
    try {
      var resp = await fetch('/node-index.json');
      nodeIndex = await resp.json();
      return nodeIndex;
    } catch (_) { return []; }
  }

  function searchNodes(nodes, query) {
    var q = query.toLowerCase();
    var hits = [];
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      if (n.title.toLowerCase().indexOf(q) >= 0 || n.summary.toLowerCase().indexOf(q) >= 0) {
        hits.push(n);
      }
    }
    hits.sort(function (a, b) {
      var aT = a.title.toLowerCase().indexOf(q) >= 0 ? 0 : 1;
      var bT = b.title.toLowerCase().indexOf(q) >= 0 ? 0 : 1;
      return aT - bT;
    });
    return hits;
  }

  function renderResults(results) {
    if (!results || results.length === 0) {
      panelBody.innerHTML =
        '<div class="sel-empty">未找到匹配结果</div>';
      return;
    }
    var html = '';
    for (var i = 0; i < results.length; i++) {
      var r = results[i];
      html += '<div class="sel-result" data-href="/node/' + r.id + '/">' +
        '<div class="sel-result-title"><a href="/node/' + r.id + '/">' + esc(r.title) + '</a></div>' +
        '<div class="sel-result-excerpt">' + esc(r.summary) + '</div>' +
        '</div>';
    }
    panelBody.innerHTML = html;
    panelBody.querySelectorAll('.sel-result').forEach(function (card) {
      card.addEventListener('click', function () {
        window.location.href = card.dataset.href;
      });
    });
  }

  function esc(str) {
    if (!str) return '';
    var d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }
})();
</script>
