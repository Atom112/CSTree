---
// SelectionSearch — 选中文本后的浮动工具栏
// 仅在知识节点内容页生效 (.knowledge-content 区域内)
// 提供：复制、搜索网络、知识库搜索、问 AI 四个操作
// AI 模式：默认免费 API (硅基流动)，离线降级 Transformers.js 浏览器模型
---

<style is:global>
  /* ════════════════════════════════════════════════
     Selection toolbar
     ════════════════════════════════════════════════ */
  .sel-popup {
    position: fixed;
    z-index: 2147483646;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.16);
    padding: 4px;
    display: none;
    pointer-events: auto;
    user-select: none;
    align-items: stretch;
    gap: 0;
    transition: opacity 0.15s, transform 0.15s;
    opacity: 0;
    transform: translateY(4px);
  }
  .sel-popup.visible { display: flex; opacity: 1; transform: translateY(0); }
  .dark .sel-popup {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .sel-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 6px;
    cursor: pointer;
    color: #1e293b;
    transition: background 0.12s;
    white-space: nowrap;
  }
  .sel-btn:hover { background: #f1f5f9; }
  .sel-btn:active { transform: scale(0.96); }
  .dark .sel-btn { color: #e2e8f0; }
  .dark .sel-btn:hover { background: #334155; }
  .sel-btn-svg { width: 15px; height: 15px; flex-shrink: 0; }
  .sel-btn-label { font-size: 12px; font-weight: 500; line-height: 1; }
  .sel-btn-svg-check { display: none; }
  .sel-btn.copied .sel-btn-svg-default { display: none; }
  .sel-btn.copied .sel-btn-svg-check { display: block; }

  /* ── AI button accent (subtle purple tint) ── */
  .sel-btn[data-action="aiask"] { color: #7c3aed; }
  .sel-btn[data-action="aiask"]:hover { background: #f5f3ff; }
  .dark .sel-btn[data-action="aiask"] { color: #a78bfa; }
  .dark .sel-btn[data-action="aiask"]:hover { background: #2e1065; }

  .sel-sep {
    width: 1px;
    margin: 6px 2px;
    background: #e2e8f0;
    flex-shrink: 0;
  }
  .dark .sel-sep { background: #334155; }

  /* ════════════════════════════════════════════════
     Shared panel base
     ════════════════════════════════════════════════ */
  .sel-panel-base {
    position: fixed;
    z-index: 2147483645;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    display: none;
    pointer-events: auto;
    width: 460px;
    max-width: calc(100vw - 32px);
    max-height: min(540px, 70vh);
    overflow-y: auto;
    animation: sel-pop-in 0.18s ease-out;
  }
  .sel-panel-base.visible { display: block; }
  @keyframes sel-pop-in {
    from { transform: translateY(8px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .dark .sel-panel-base {
    background: #1e293b;
    border-color: #334155;
    box-shadow: 0 8px 32px rgba(0,0,0,0.6);
  }

  .sel-panel-hd {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px 10px;
    border-bottom: 1px solid #e2e8f0;
    position: sticky;
    top: 0;
    background: inherit;
    border-radius: 12px 12px 0 0;
    z-index: 2;
  }
  .dark .sel-panel-hd { border-bottom-color: #334155; }
  .sel-panel-title {
    font-size: 13px;
    font-weight: 600;
    color: #475569;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .dark .sel-panel-title { color: #94a3b8; }
  .sel-panel-query {
    color: #1e293b;
    font-weight: 700;
  }
  .dark .sel-panel-query { color: #f1f5f9; }

  .sel-panel-hdbtn {
    background: none;
    border: none;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    flex-shrink: 0;
    transition: background 0.12s, color 0.12s;
  }
  .sel-panel-hdbtn:hover { background: #f1f5f9; color: #475569; }
  .dark .sel-panel-hdbtn:hover { background: #334155; color: #cbd5e1; }
  .sel-panel-hdbtn svg { width: 16px; height: 16px; }

  .sel-panel-bd { padding: 12px 16px 16px; }

  /* ════════════════════════════════════════════════
     KB search panel (reuses sel-panel-base)
     ════════════════════════════════════════════════ */
  .sel-result {
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 4px;
    transition: background 0.12s;
    cursor: pointer;
  }
  .sel-result:hover { background: #f8fafc; }
  .dark .sel-result:hover { background: #0f172a; }
  .sel-result:last-child { margin-bottom: 0; }
  .sel-result-title { font-size: 14px; font-weight: 600; margin-bottom: 2px; }
  .sel-result-title a { color: #2563eb; text-decoration: none; }
  .sel-result-title a:hover { text-decoration: underline; }
  .dark .sel-result-title a { color: #60a5fa; }
  .sel-result-excerpt {
    font-size: 12px;
    color: #64748b;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .dark .sel-result-excerpt { color: #94a3b8; }
  .sel-result-excerpt mark {
    background: #fef08a; padding: 0 1px; border-radius: 1px; color: inherit;
  }
  .dark .sel-result-excerpt mark {
    background: rgba(113, 63, 18, 0.5); color: #fbbf24;
  }

  .sel-loading {
    text-align: center; padding: 32px 16px; color: #94a3b8; font-size: 13px;
  }
  .sel-loading::after {
    content: '';
    display: inline-block;
    width: 16px; height: 16px; margin-left: 6px;
    border: 2px solid #e2e8f0; border-top-color: #3b82f6;
    border-radius: 50%;
    animation: sel-spin 0.6s linear infinite;
    vertical-align: middle;
  }
  .dark .sel-loading::after {
    border-color: #334155; border-top-color: #60a5fa;
  }
  @keyframes sel-spin { to { transform: rotate(360deg); } }

  .sel-empty { text-align: center; padding: 32px 16px; color: #94a3b8; font-size: 13px; }
  .sel-error { text-align: center; padding: 24px 16px; color: #ef4444; font-size: 13px; }
  .sel-error-hint { margin-top: 6px; font-size: 12px; color: #94a3b8; }
  .sel-error-hint a { color: #2563eb; text-decoration: underline; }
  .dark .sel-error-hint a { color: #60a5fa; }

  /* ════════════════════════════════════════════════
     AI panel
     ════════════════════════════════════════════════ */
  .ai-hd-icon { color: #7c3aed; }
  .dark .ai-hd-icon { color: #a78bfa; }

  .ai-body {
    font-size: 14px;
    line-height: 1.7;
    color: #1e293b;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .dark .ai-body { color: #e2e8f0; }

  .ai-body p { margin: 0 0 8px; }
  .ai-body p:last-child { margin-bottom: 0; }
  .ai-body strong { font-weight: 600; }
  .ai-body em { font-style: italic; }
  .ai-body code {
    font-size: 12px; padding: 1px 4px; border-radius: 3px;
    background: #f1f5f9; font-family: 'Menlo', 'Consolas', monospace;
  }
  .dark .ai-body code { background: #1e293b; }
  .ai-body a { color: #2563eb; text-decoration: underline; }
  .dark .ai-body a { color: #60a5fa; }

  .ai-think {
    color: #94a3b8;
    font-style: italic;
    font-size: 13px;
  }
  .ai-cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: #7c3aed;
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: ai-blink 0.8s step-end infinite;
  }
  .dark .ai-cursor { background: #a78bfa; }
  .ai-cursor.done { display: none; }
  @keyframes ai-blink { 50% { opacity: 0; } }

  /* ── AI sources ── */
  .ai-sources {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid #e2e8f0;
  }
  .dark .ai-sources { border-top-color: #334155; }
  .ai-sources-title {
    font-size: 11px;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .ai-source-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #2563eb;
    text-decoration: none;
    padding: 3px 8px;
    border-radius: 4px;
    background: #f1f5f9;
    margin: 2px 4px 2px 0;
    transition: background 0.12s;
  }
  .ai-source-link:hover { background: #dbeafe; }
  .dark .ai-source-link { color: #60a5fa; background: #1e293b; }
  .dark .ai-source-link:hover { background: #1e3a5f; }

  /* ── AI progress (model download) ── */
  .ai-progress-wrap { padding: 24px 16px; text-align: center; }
  .ai-progress-label {
    font-size: 13px; color: #64748b; margin-bottom: 10px;
  }
  .dark .ai-progress-label { color: #94a3b8; }
  .ai-progress-bar {
    width: 100%; height: 6px;
    background: #e2e8f0; border-radius: 3px; overflow: hidden;
    margin-bottom: 6px;
  }
  .dark .ai-progress-bar { background: #334155; }
  .ai-progress-fill {
    height: 100%; width: 0%;
    background: linear-gradient(90deg, #7c3aed, #a78bfa);
    border-radius: 3px;
    transition: width 0.3s;
  }
  .ai-progress-info { font-size: 11px; color: #94a3b8; }

  /* ── API key config ── */
  .ai-config { padding: 20px 16px; }
  .ai-config h3 {
    font-size: 15px; font-weight: 600; margin: 0 0 4px; color: #1e293b;
  }
  .dark .ai-config h3 { color: #f1f5f9; }
  .ai-config p {
    font-size: 12px; color: #64748b; margin: 0 0 12px; line-height: 1.5;
  }
  .dark .ai-config p { color: #94a3b8; }
  .ai-config-input {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 13px;
    font-family: 'Menlo', 'Consolas', monospace;
    outline: none;
    box-sizing: border-box;
    background: #fff;
    color: #1e293b;
    transition: border-color 0.15s;
  }
  .ai-config-input:focus { border-color: #7c3aed; }
  .dark .ai-config-input { background: #1e293b; color: #e2e8f0; border-color: #475569; }
  .dark .ai-config-input:focus { border-color: #a78bfa; }

  .ai-config-row {
    display: flex; gap: 8px; align-items: center; margin-top: 8px;
  }
  .ai-config-btn {
    padding: 7px 16px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    transition: background 0.12s;
    white-space: nowrap;
  }
  .ai-config-btn-primary {
    background: #7c3aed; color: #fff;
  }
  .ai-config-btn-primary:hover { background: #6d28d9; }
  .ai-config-btn-secondary {
    background: #f1f5f9; color: #475569;
  }
  .ai-config-btn-secondary:hover { background: #e2e8f0; }
  .dark .ai-config-btn-secondary { background: #334155; color: #cbd5e1; }
  .dark .ai-config-btn-secondary:hover { background: #475569; }

  .ai-config-status {
    font-size: 12px; color: #22c55e; margin-top: 8px;
  }
  .ai-config-error {
    font-size: 12px; color: #ef4444; margin-top: 8px;
  }
  .ai-config-hint {
    margin-top: 16px;
    padding: 12px;
    background: #f8fafc;
    border-radius: 8px;
    font-size: 12px;
    line-height: 1.6;
    color: #475569;
  }
  .dark .ai-config-hint { background: #0f172a; color: #94a3b8; }
  .ai-config-hint code {
    font-size: 11px; padding: 1px 4px; border-radius: 3px;
    background: #e2e8f0; word-break: break-all;
  }
  .dark .ai-config-hint code { background: #1e293b; }
  .ai-config-hint a { color: #2563eb; }
  .dark .ai-config-hint a { color: #60a5fa; }

  /* ── Model selector ── */
  .ai-model-section { margin-top: 16px; }
  .ai-model-section-title {
    font-size: 12px; font-weight: 600; color: #475569; margin-bottom: 8px;
  }
  .dark .ai-model-section-title { color: #94a3b8; }
  .ai-model-opts { display: flex; flex-direction: column; gap: 4px; }
  .ai-model-opt {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    cursor: pointer;
    transition: border-color 0.12s, background 0.12s;
    background: #fff;
  }
  .ai-model-opt:hover { border-color: #cbd5e1; background: #f8fafc; }
  .ai-model-opt.active { border-color: #7c3aed; background: #f5f3ff; }
  .dark .ai-model-opt { background: #1e293b; border-color: #334155; }
  .dark .ai-model-opt:hover { border-color: #475569; background: #0f172a; }
  .dark .ai-model-opt.active { border-color: #a78bfa; background: #2e1065; }
  .ai-model-opt input[type="radio"] {
    accent-color: #7c3aed; flex-shrink: 0; margin: 0; width: 14px; height: 14px;
  }
  .ai-model-label { font-size: 13px; font-weight: 600; color: #1e293b; }
  .dark .ai-model-label { color: #e2e8f0; }
  .ai-model-desc { font-size: 11px; color: #94a3b8; margin-left: auto; }
</style>

<script>
(function () {
  'use strict';

  if (!document.querySelector('.knowledge-content')) return;

  /* ==================================================================
     SVG icon snippets
     ================================================================== */
  var ICONS = {
    copy:     '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
    check:    '<polyline points="20 6 9 17 4 12"/>',
    globe:    '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    search:   '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
    sparkle:  '<path d="M12 2l1.5 6.5L20 10l-6.5 1.5L12 18l-1.5-6.5L4 10l6.5-1.5z"/><circle cx="19" cy="5" r="1.5" opacity="0.6"/><circle cx="5" cy="19" r="1.5" opacity="0.6"/>',
    gear:     '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
    refresh:  '<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>',
    close:    '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
    bulb:     '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>',
    book:     '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
  };

  function svg(path, cls) {
    return '<svg class="' + cls + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + path + '</svg>';
  }

  /* ==================================================================
     Create toolbar popup
     ================================================================== */
  var popup = document.createElement('div');
  popup.className = 'sel-popup';
  popup.innerHTML =
    '<div class="sel-btn" data-action="copy">' +
      svg(ICONS.copy, 'sel-btn-svg sel-btn-svg-default') +
      svg(ICONS.check, 'sel-btn-svg sel-btn-svg-check') +
      '<span class="sel-btn-label">复制</span>' +
    '</div>' +
    '<div class="sel-sep"></div>' +
    '<div class="sel-btn" data-action="websearch">' +
      svg(ICONS.globe, 'sel-btn-svg') +
      '<span class="sel-btn-label">搜索网络</span>' +
    '</div>' +
    '<div class="sel-sep"></div>' +
    '<div class="sel-btn" data-action="kbsearch">' +
      svg(ICONS.search, 'sel-btn-svg') +
      '<span class="sel-btn-label">知识库搜索</span>' +
    '</div>' +
    '<div class="sel-sep"></div>' +
    '<div class="sel-btn" data-action="aiask">' +
      svg(ICONS.sparkle, 'sel-btn-svg') +
      '<span class="sel-btn-label">问AI</span>' +
    '</div>';
  document.body.appendChild(popup);

  /* ==================================================================
     Create shared panel element (reused for KB search & AI)
     ================================================================== */
  var panel = document.createElement('div');
  panel.className = 'sel-panel-base';
  panel.innerHTML =
    '<div class="sel-panel-hd">' +
    '  <div class="sel-panel-title"></div>' +
    '  <button class="sel-panel-hdbtn sel-panel-refresh" title="重新回答">' +
        svg(ICONS.refresh, '') +
    '  </button>' +
    '  <button class="sel-panel-hdbtn sel-panel-config" title="AI 设置">' +
        svg(ICONS.gear, '') +
    '  </button>' +
    '  <button class="sel-panel-hdbtn sel-panel-close" title="关闭">&times;</button>' +
    '</div>' +
    '<div class="sel-panel-bd"></div>';
  document.body.appendChild(panel);

  var panelTitle  = panel.querySelector('.sel-panel-title');
  var panelBody   = panel.querySelector('.sel-panel-bd');
  var panelClose  = panel.querySelector('.sel-panel-close');
  var panelConfig = panel.querySelector('.sel-panel-config');
  var panelRefresh= panel.querySelector('.sel-panel-refresh');

  /* ==================================================================
     State
     ================================================================== */
  var selectedText = '';
  var selectionRect = null;
  var popupTimer = null;
  var nodeIndex = null;
  var activeMode = null;   // 'kb' | 'ai'
  var aiAbortCtrl = null;  // AbortController for AI stream
  var localModel = null;   // Transformers.js pipeline (lazy)

  /* ------------------------------------------------------------------
     Model list
     Display names shown to user, API IDs sent to SiliconFlow
     ------------------------------------------------------------------ */
  var AI_MODELS = [
    { id: 'Qwen/Qwen3-8B',             label: 'Qwen3-8B',          desc: '通义千问 Qwen3（默认）' },
    { id: 'THUDM/GLM-Z1-9B-0414',       label: 'GLM Z1-9B',        desc: '智谱 GLM 推理版' },
    { id: 'deepseek-ai/DeepSeek-R1-0528-Qwen3-8B', label: 'DeepSeek R1-8B', desc: 'DeepSeek 推理增强' },
  ];
  var AI_MODEL_KEY = 'cstree_ai_model';

  function getSelectedModel() {
    try {
      var stored = localStorage.getItem(AI_MODEL_KEY);
      if (stored) return stored;
    } catch(_) {}
    return AI_MODELS[0].id;
  }
  function setSelectedModel(id) { try { localStorage.setItem(AI_MODEL_KEY, id); } catch(_) {} }

  /* ------------------------------------------------------------------
     API key management
     ─ Built-in key comes from build-time env var PUBLIC_SILICONFLOW_API_KEY
       (set in Cloudflare Pages dashboard or .env file)
     ─ Users can still override with their own key via the settings panel
     ------------------------------------------------------------------ */
  var AI_KEY = 'cstree_ai_api_key';
  var AI_MODE = 'cstree_ai_mode';  // 'api' | 'local'

  // Build-time injected API key (set by site owner via Cloudflare Pages env vars)
  var BUILTIN_KEY = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_SILICONFLOW_API_KEY) || '';

  function getApiKey() {
    // localStorage override takes priority (user can manually enter a different key)
    try {
      var stored = localStorage.getItem(AI_KEY);
      if (stored) return stored;
    } catch(_) {}
    return BUILTIN_KEY;
  }
  function setApiKey(k) { try { localStorage.setItem(AI_KEY, k); } catch(_) {} }
  function clearApiKey() { try { localStorage.removeItem(AI_KEY); } catch(_) {} }
  function hasApiKey() { return !!getApiKey(); }

  function getAiMode() {
    // If built-in key exists, default to API mode
    if (BUILTIN_KEY) return 'api';
    try { return localStorage.getItem(AI_MODE) || 'api'; } catch(_) { return 'api'; }
  }
  function setAiMode(m) { try { localStorage.setItem(AI_MODE, m); } catch(_) {} }

  /* ==================================================================
     Popup positioning
     ================================================================== */
  function showPopup(rect) {
    var popupH = 42;
    var gap = 8;
    var top = rect.top - popupH - gap;
    if (top < gap) top = rect.bottom + gap;
    var popupW = 360;
    var left = rect.left + (rect.width / 2) - (popupW / 2);
    left = Math.max(gap, Math.min(left, window.innerWidth - popupW - gap));
    popup.style.left = left + 'px';
    popup.style.top = top + 'px';
    popup.classList.add('visible');
  }

  function hidePopup() { popup.classList.remove('visible'); }

  /* ==================================================================
     Panel positioning (shared between KB search & AI)
     ================================================================== */
  function showPanel(rect) {
    var panelW = 460;
    var panelH = Math.min(540, window.innerHeight * 0.7);
    var gap = 10;
    var left = rect.left + (rect.width / 2) - (panelW / 2);
    left = Math.max(8, Math.min(left, window.innerWidth - panelW - 8));
    var below = rect.bottom + gap;
    var above = rect.top - panelH - gap;
    var top;
    if (below + panelH <= window.innerHeight) top = below;
    else if (above >= 0) top = above;
    else top = Math.max(8, (window.innerHeight - panelH) / 2);
    panel.style.left = left + 'px';
    panel.style.top = top + 'px';
    panel.classList.add('visible');
  }

  function hidePanel() {
    if (aiAbortCtrl) { aiAbortCtrl.abort(); aiAbortCtrl = null; }
    panel.classList.remove('visible');
    panelBody.innerHTML = '';
    panelTitle.textContent = '';
    panelRefresh.style.display = 'none';
    panelConfig.style.display = 'none';
    activeMode = null;
  }

  /* ==================================================================
     Actions — existing
     ================================================================== */
  function doCopy(text, btn) {
    if (!text) return;
    (navigator.clipboard ? navigator.clipboard.writeText(text) : Promise.reject())
      .catch(function () {
        var ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.left = '-9999px';
        document.body.appendChild(ta); ta.select();
        document.execCommand('copy'); document.body.removeChild(ta);
      });
    btn.classList.add('copied');
    setTimeout(function () { btn.classList.remove('copied'); }, 1200);
    hidePopup();
  }

  function doWebSearch(text) {
    if (!text) return;
    window.open('https://www.google.com/search?q=' + encodeURIComponent(text), '_blank', 'noopener');
    hidePopup();
  }

  async function doKBSearch(text, rect) {
    if (!text || !rect) return;
    hidePopup();
    activeMode = 'kb';
    panelRefresh.style.display = 'none';
    panelConfig.style.display = 'none';
    panelTitle.innerHTML = '在知识库中搜索 <span class="sel-panel-query">' + esc(text) + '</span>';
    panelBody.innerHTML = '<div class="sel-loading">正在搜索</div>';
    showPanel(rect);
    var idx = await loadNodeIndex();
    renderResults(searchNodes(idx, text));
  }

  /* ==================================================================
     Actions — AI
     ================================================================== */

  // ── Main AI entry point ──
  function doAskAI(text, rect, forceConfig) {
    if (!text || !rect) return;
    hidePopup();
    activeMode = 'ai';
    panelRefresh.style.display = 'none';
    panelConfig.style.display = 'block';

    var apiKey = getApiKey();
    if (!apiKey || forceConfig) {
      showAIConfig(text, rect);
      return;
    }

    var mode = getAiMode();
    if (mode === 'api') {
      doAskAI_API(text, rect);
    } else {
      doAskAI_Local(text, rect);
    }
  }

  // ── API mode ──
  async function doAskAI_API(text, rect) {
    panelRefresh.style.display = 'none';
    panelTitle.innerHTML = '🤖 <span class="sel-panel-query">' + esc(text) + '</span>';
    panelBody.innerHTML = '<div class="sel-loading">AI 思考中</div>';
    showPanel(rect);

    var context = buildRAGContext(text);
    var apiKey = getApiKey();
    if (!apiKey) { showAIConfig(text, rect); return; }

    var systemMsg = '你是一个计算机科学知识助手。请用中文回答。回答时可以参考以下知识库内容（如果相关）：\n\n' +
      context +
      '\n\n如果知识库内容不相关或不充分，请基于你自己的知识回答。回答应简洁明了，适合初学者理解。';

    var body = JSON.stringify({
      model: getSelectedModel(),
      messages: [
        { role: 'system', content: systemMsg },
        { role: 'user', content: '请解释：' + text }
      ],
      stream: true,
      temperature: 0.3,
      max_tokens: 2048
    });

    aiAbortCtrl = new AbortController();

    var resp;
    try {
      resp = await fetch('https://api.siliconflow.cn/v1/chat/completions', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + apiKey,
          'Content-Type': 'application/json'
        },
        body: body,
        signal: aiAbortCtrl.signal
      });
    } catch (err) {
      if (err.name === 'AbortError') return;
      // Network error → fallback to local model
      setAiMode('local');
      doAskAI_Local(text, rect);
      return;
    }

    if (!resp.ok) {
      if (resp.status === 401 || resp.status === 403) {
        // Auth error → show config
        showAIConfig(text, rect, 'API Key 无效，请重新配置');
        return;
      }
      // Other API error → fallback
      setAiMode('local');
      doAskAI_Local(text, rect);
      return;
    }

    // ── Stream response ──
    panelRefresh.style.display = 'none';
    panelBody.innerHTML = '<div class="ai-body"><span class="ai-cursor"></span></div>';
    var aiBodyEl = panelBody.querySelector('.ai-body');
    var cursorEl = panelBody.querySelector('.ai-cursor');
    var fullText = '';
    var buffer = '';

    var reader = resp.body.getReader();
    var decoder = new TextDecoder();

    try {
      while (true) {
        var readResult = await reader.read();
        if (readResult.done) break;
        buffer += decoder.decode(readResult.value, { stream: true });
        // Parse SSE: "data: {...}\n\n"
        var lines = buffer.split('\n');
        buffer = lines.pop() || '';  // keep incomplete line
        for (var li = 0; li < lines.length; li++) {
          var line = lines[li].trim();
          if (!line || line === 'data: [DONE]') continue;
          if (line.indexOf('data: ') !== 0) continue;
          try {
            var json = JSON.parse(line.slice(6));
            var delta = json.choices && json.choices[0] && json.choices[0].delta;
            if (delta && delta.content) {
              fullText += delta.content;
              // Simple markdown rendering
              aiBodyEl.innerHTML = renderMarkdown(fullText) + '<span class="ai-cursor"></span>';
              aiBodyEl.scrollTop = aiBodyEl.scrollHeight;
            }
          } catch (_) {}
        }
      }
    } catch (err) {
      if (err.name === 'AbortError') return;
    }

    // Done — remove cursor, show sources
    cursorEl.classList.add('done');
    showAISources(context);
    panelRefresh.style.display = 'block';
  }

  // ── Local model mode (Transformers.js fallback) ──
  async function doAskAI_Local(text, rect) {
    panelRefresh.style.display = 'none';
    panelTitle.innerHTML = '🤖 <span class="sel-panel-query">' + esc(text) + '</span> (离线)';

    var context = buildRAGContext(text);

    // Show progress initially
    panelBody.innerHTML =
      '<div class="ai-progress-wrap">' +
      '  <div class="ai-progress-label">正在加载 AI 模型</div>' +
      '  <div class="ai-progress-bar"><div class="ai-progress-fill"></div></div>' +
      '  <div class="ai-progress-info">首次加载需下载约 350MB 模型文件</div>' +
      '</div>';
    showPanel(rect);

    try {
      // Dynamic import of Transformers.js from CDN
      var HF = await import('https://cdn.jsdelivr.net/npm/@huggingface/transformers@4.2.0/dist/transformers.min.js');
      var progressFill = panelBody.querySelector('.ai-progress-fill');
      var progressInfo = panelBody.querySelector('.ai-progress-info');

      var generator = await HF.pipeline('text-generation',
        'onnx-community/Qwen2.5-0.5B-Instruct',
        {
          dtype: 'q4',
          device: navigator.gpu ? 'webgpu' : 'wasm',
          progress_callback: function (p) {
            if (progressFill && p.status === 'progress') {
              var pct = Math.round((p.loaded / p.total) * 100);
              progressFill.style.width = pct + '%';
              if (progressInfo) {
                progressInfo.textContent = '下载中 ' + pct + '% · ' +
                  formatSize(p.loaded) + ' / ' + formatSize(p.total);
              }
            }
          }
        }
      );

      localModel = generator;

      // Generate
      panelBody.innerHTML = '<div class="ai-body"><span class="ai-cursor"></span></div>';
      var aiBodyEl = panelBody.querySelector('.ai-body');
      var cursorEl = panelBody.querySelector('.ai-cursor');

      var prompt = '你是一个计算机科学知识助手。用中文简洁回答。\n\n相关知识：\n' +
        context + '\n\n问题：' + text;

      var output = await generator(prompt, {
        max_new_tokens: 512,
        temperature: 0.3,
        do_sample: false
      });

      var answer = output[0].generated_text;
      // Strip the prompt from the generated text
      if (answer.indexOf(prompt) === 0) {
        answer = answer.slice(prompt.length).trim();
      }

      aiBodyEl.innerHTML = renderMarkdown(answer);
      cursorEl.classList.add('done');
      showAISources(context);
      panelRefresh.style.display = 'block';

    } catch (err) {
      panelBody.innerHTML =
        '<div class="sel-error">离线模型加载失败</div>' +
        '<div class="sel-error-hint" style="text-align:center">' +
        '请检查网络连接后重试，或 <a href="#" class="ai-retry-api">切换为 API 模式</a></div>';
      panelBody.querySelector('.ai-retry-api').addEventListener('click', function (e) {
        e.preventDefault();
        setAiMode('api');
        doAskAI_API(text, rect);
      });
    }
  }

  // ── Show AI configuration overlay ──
  function showAIConfig(text, rect, errorMsg) {
    panelRefresh.style.display = 'none';
    panelConfig.style.display = 'none';
    panelTitle.textContent = '🤖 AI 设置';
    var apiKey = getApiKey();
    var hasBuiltin = !!BUILTIN_KEY;

    var statusHtml;
    if (apiKey && hasBuiltin) {
      statusHtml = '<div class="ai-config-status">✅ AI 服务已就绪（站长预配置）</div>';
    } else if (apiKey) {
      statusHtml = '<div class="ai-config-status">✅ API Key 已配置</div>';
    } else {
      statusHtml = '<div class="ai-config-error" style="color:#94a3b8">⚠️ 尚未配置 API Key</div>';
    }

    var errorHtml = errorMsg
      ? '<div class="ai-config-error">' + esc(errorMsg) + '</div>'
      : '';

    var inputVal = esc(apiKey || '');
