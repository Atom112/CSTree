---
export interface Props {
  nodeId: string;
  nodeMap: Map<string, {
    id: string;
    title: string;
    summary: string;
    difficulty: string;
    children: string[];
    parent?: string | null;
  }>;
  getChildren: (id: string) => Array<{
    id: string;
    title: string;
    summary: string;
    difficulty: string;
    children: string[];
    parent?: string | null;
  }>;
  depth: number;
}

const { nodeId, nodeMap, getChildren, depth } = Astro.props;
const node = nodeMap.get(nodeId);
if (!node) return;

const children = getChildren(nodeId);
const indent = depth * 20;
const Self = Astro.self;

const difficultyColors: Record<string, string> = {
  beginner: 'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300',
  intermediate: 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300',
  advanced: 'bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300',
};
const difficultyLabels: Record<string, string> = {
  beginner: '入门',
  intermediate: '进阶',
  advanced: '高级',
};
---

<div style="margin-left: {indent}px">
  <a
    href={`/node/${nodeId}`}
    class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors group"
  >
    {children.length > 0 ? (
      <span class="text-xs text-gray-400 group-hover:text-blue-500 transition-colors inline-flex items-center">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></svg>
      </span>
    ) : (
      <span class="text-xs text-gray-400 inline-flex items-center">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
      </span>
    )}
    <span class="font-medium text-sm group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      {node.title}
    </span>
    <span class="text-xs {difficultyColors[node.difficulty] || difficultyColors.beginner} px-1.5 py-0.5 rounded">
      {difficultyLabels[node.difficulty] || node.difficulty}
    </span>
    {!node.parent && (
      <span class="text-xs text-gray-400 dark:text-gray-500 inline-flex items-center gap-0.5">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.5 17 2 17 2S15.5 8.3 13.8 12C12.3 15.5 11 20 11 20z" /><path d="M11 20v-6" /></svg>
        根节点
      </span>
    )}
  </a>

  {children.length > 0 && (
    <div class="border-l-2 border-gray-200 dark:border-gray-700 ml-2 pl-2 mt-1 mb-1">
      {children.map((child) => (
        <Self
          nodeId={child.id}
          nodeMap={nodeMap}
          getChildren={getChildren}
          depth={depth + 1}
        />
      ))}
    </div>
  )}
</div>
