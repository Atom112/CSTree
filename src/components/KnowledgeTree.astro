---
import KnowledgeTreeReact from './KnowledgeTreeReact';
import MobileTreeList from './MobileTreeList.astro';

export interface Props {
  nodes: Array<{
    id: string;
    title: string;
    summary: string;
    difficulty?: string;
    parent?: string | null;
    children: string[];
    related: string[];
  }>;
  currentId?: string;
}

const { nodes, currentId } = Astro.props;
---

<div class="knowledge-tree-container w-full min-h-[400px]">
  <!-- Mobile: collapsible tree list (<details> element, zero JS) -->
  <div class="block lg:hidden">
    <MobileTreeList nodes={nodes} currentId={currentId} />
  </div>

  <!-- Desktop: React + D3 interactive tree -->
  <div class="hidden lg:block w-full h-[520px] bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden">
    <KnowledgeTreeReact
      client:load
      nodes={nodes.map((n) => ({
        id: n.id,
        title: n.title,
        summary: n.summary,
        parent: n.parent,
        children: n.children,
        difficulty: n.difficulty,
      }))}
      currentNodeId={currentId}
    />
  </div>

  <!-- Footer hint -->
  <p class="text-xs text-gray-400 dark:text-gray-500 mt-2 text-center lg:text-left">
    {nodes.length} 个知识节点
    {currentId && <> · 当前：<span class="font-medium text-gray-500 dark:text-gray-400">{nodes.find((n) => n.id === currentId)?.title ?? currentId}</span></>}
     · 滚轮缩放 · 点击跳转
  </p>
</div>
