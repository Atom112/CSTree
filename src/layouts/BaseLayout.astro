---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  nodeId?: string;
  /** JSON-LD structured data (array of objects) */
  structuredData?: Record<string, unknown>[];
  /** Published date for article pages */
  publishedAt?: string;
  /** Updated date for article pages */
  updatedAt?: string;
}

const { title, description, nodeId, structuredData, publishedAt, updatedAt } = Astro.props;
const siteTitle = title ? `${title} | CSTree` : 'CSTree — 计算机科学知识树';
const desc = description || '自底向上学习计算机科学——从晶体管到操作系统，从二进制到编译器';
const canonicalUrl = nodeId
  ? `https://cstree.example.com/node/${nodeId}/`
  : 'https://cstree.example.com/';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary meta -->
    <title>{siteTitle}</title>
    <meta name="description" content={desc} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={nodeId ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="CSTree" />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={desc} />

    <!-- Article meta -->
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt} />}

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify([
      {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'CSTree',
        description: '自底向上学习计算机科学',
        url: 'https://cstree.example.com/',
      },
      ...(nodeId ? [{
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description: desc,
        url: canonicalUrl,
        ...(publishedAt ? { datePublished: publishedAt } : {}),
        ...(updatedAt ? { dateModified: updatedAt } : {}),
      }] : []),
      ...(structuredData || []),
    ])} />

    <!-- Dark mode init (FOUC prevention) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('cstree-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-40 bg-white/80 dark:bg-gray-950/80 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800">
      <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-lg hover:text-blue-600 dark:hover:text-blue-400 transition-colors whitespace-nowrap">
          🌳 CSTree
        </a>
        <div class="flex items-center gap-3 text-sm">
          <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">知识树</a>
          <a href="/nodes" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">目录</a>
          <a href="/search" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">搜索</a>

          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            class="ml-2 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-lg"
            aria-label="切换暗色模式"
            title="切换暗色模式"
          >
            <span id="theme-icon" class="block">🌙</span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 py-8 mt-12">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>CSTree — 自底向上学习计算机科学</p>
        <p class="mt-1">Built with Astro</p>
      </div>
    </footer>

    <!-- Dark mode toggle script -->
    <script>
      const btn = document.getElementById('theme-toggle');
      const icon = document.getElementById('theme-icon');
      if (btn && icon) {
        const updateIcon = () => {
          const isDark = document.documentElement.classList.contains('dark');
          icon.textContent = isDark ? '☀️' : '🌙';
        };
        updateIcon();
        btn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark');
          if (isDark) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('cstree-theme', 'light');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('cstree-theme', 'dark');
          }
          updateIcon();
        });
      }
    </script>
  </body>
</html>
