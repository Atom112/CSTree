---
export interface Props {
  title: string;
  description?: string;
  nodeId?: string;
}

const { title, description, nodeId } = Astro.props;
const siteTitle = title ? `${title} | CSTree` : 'CSTree — 计算机科学知识树';
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || '自底向上学习计算机科学'} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description || '自底向上学习计算机科学'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-40 bg-white/80 dark:bg-gray-950/80 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800">
      <nav class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-lg hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
          🌳 CSTree
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">知识树</a>
          <a href="/nodes" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">目录</a>
          <a href="/search" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">搜索</a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 dark:border-gray-800 py-8 mt-12">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500 dark:text-gray-400">
        <p>CSTree — 自底向上学习计算机科学</p>
        <p class="mt-1">Built with Astro • Open on GitHub</p>
      </div>
    </footer>
  </body>
</html>
