---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { resolveGraph, topologicalSort } from '../utils/graph';
import { fromCollection } from '../utils/types';

const entries = await getCollection('node');
const nodeData = fromCollection(entries);
const graph = resolveGraph(nodeData);

const rootNodes = graph.rootNodes;
const sortedNodes = topologicalSort(nodeData);

// Stats
const totalNodes = nodeData.length;
const beginnerCount = nodeData.filter((n) => n.difficulty === 'beginner').length;
const intermediateCount = nodeData.filter((n) => n.difficulty === 'intermediate').length;
const advancedCount = nodeData.filter((n) => n.difficulty === 'advanced').length;

const hasAdvanced = advancedCount > 0;
---

<BaseLayout title="节点目录">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">知识节点目录</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-6">浏览所有知识节点</p>

    <!-- Stats cards — click to filter -->
    <div
      id="difficulty-stats"
      class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8"
    >
      <button data-filter="all"
        class="stat-card active p-4 rounded-lg bg-gray-50 dark:bg-gray-800/30 border border-gray-200 dark:border-gray-700 text-center cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-all">
        <div class="text-2xl font-bold text-gray-600 dark:text-gray-300">{totalNodes}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">全部</div>
      </button>
      <button data-filter="beginner"
        class="stat-card p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-center cursor-pointer hover:bg-green-100 dark:hover:bg-green-900/40 transition-all">
        <div class="text-2xl font-bold text-green-600 dark:text-green-400">{beginnerCount}</div>
        <div class="text-xs text-green-600/70 dark:text-green-400/70 mt-0.5">入门</div>
      </button>
      <button data-filter="intermediate"
        class="stat-card p-4 rounded-lg bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-center cursor-pointer hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-all">
        <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">{intermediateCount}</div>
        <div class="text-xs text-blue-600/70 dark:text-blue-400/70 mt-0.5">进阶</div>
      </button>
      <button data-filter="advanced"
        class="stat-card p-4 rounded-lg bg-violet-50 dark:bg-violet-900/20 border border-violet-200 dark:border-violet-800 text-center cursor-pointer hover:bg-violet-100 dark:hover:bg-violet-900/40 transition-all {hasAdvanced ? '' : 'opacity-50'}">
        <div class="text-2xl font-bold text-violet-600 dark:text-violet-400">{advancedCount}</div>
        <div class="text-xs text-violet-600/70 dark:text-violet-400/70 mt-0.5">高级</div>
      </button>
    </div>

    <!-- Active filter indicator -->
    <div id="filter-indicator" class="hidden text-sm text-gray-500 dark:text-gray-400 mb-4">
      正在筛选：<span id="filter-label" class="font-medium"></span>
      <button id="clear-filter" class="ml-2 text-blue-500 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 underline">清除</button>
    </div>

    <!-- Learning Path -->
    <section>
      <h2 class="text-xl font-bold mb-4">📋 推荐学习路径</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        基于前置依赖关系的拓扑排序，建议按此顺序学习
      </p>
      <div id="learning-path" class="space-y-2">
        {sortedNodes.map((n, i) => {
          const children = graph.getChildren(n.id);
          const diffBadge = n.difficulty === 'beginner'
            ? 'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300'
            : n.difficulty === 'intermediate'
              ? 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300'
              : 'bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300';
          const diffLabel = n.difficulty === 'beginner' ? '入门' : n.difficulty === 'intermediate' ? '进阶' : '高级';
          return (
            <div class="node-item flex items-start gap-3 p-3 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors" data-difficulty={n.difficulty}>
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 flex items-center justify-center text-xs font-bold mt-0.5">
                {i + 1}
              </span>
              <div class="flex-1 min-w-0">
                <a
                  href={`/node/${n.id}`}
                  class="font-medium hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                >
                  {n.title}
                </a>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 truncate">
                  {n.summary}
                </p>
                <div class="flex flex-wrap gap-1.5 mt-1">
                  {n.tags.map((tag) => (
                    <span class="text-xs text-gray-400 dark:text-gray-500">#{tag}</span>
                  ))}
                  {children.length > 0 && (
                    <span class="text-xs text-blue-400">{children.length} 个子节点</span>
                  )}
                  {n.prerequisites.length > 0 && (
                    <span class="text-xs text-amber-400">{n.prerequisites.length} 个前置</span>
                  )}
                </div>
              </div>
              <span class={"flex-shrink-0 text-xs px-2 py-0.5 rounded " + diffBadge}>
                {diffLabel}
              </span>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  (function() {
    const statCards = document.querySelectorAll('#difficulty-stats .stat-card');
    const items = document.querySelectorAll('#learning-path .node-item');
    const indicator = document.getElementById('filter-indicator');
    const filterLabel = document.getElementById('filter-label');
    const clearBtn = document.getElementById('clear-filter');

    const difficultyLabels = {
      beginner: '入门',
      intermediate: '进阶',
      advanced: '高级',
    };

    const cardClasses = {
      all: {
        ring: 'ring-2 ring-gray-400 dark:ring-gray-500 ring-offset-2 dark:ring-offset-gray-900',
      },
      beginner: {
        ring: 'ring-2 ring-green-400 dark:ring-green-500 ring-offset-2 dark:ring-offset-gray-900',
      },
      intermediate: {
        ring: 'ring-2 ring-blue-400 dark:ring-blue-500 ring-offset-2 dark:ring-offset-gray-900',
      },
      advanced: {
        ring: 'ring-2 ring-violet-400 dark:ring-violet-500 ring-offset-2 dark:ring-offset-gray-900',
      },
    };

    function removeAllRings() {
      statCards.forEach((card) => {
        Object.values(cardClasses).forEach((cls) => {
          cls.ring.split(' ').forEach((c) => card.classList.remove(c));
        });
      });
    }

    function applyFilter(filter) {
      // Update item visibility
      items.forEach((item) => {
        if (filter === 'all' || item.dataset.difficulty === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });

      // Update stat card highlights
      removeAllRings();
      const activeCard = document.querySelector(`#difficulty-stats [data-filter="${filter}"]`);
      if (activeCard && cardClasses[filter]) {
        cardClasses[filter].ring.split(' ').forEach((c) => activeCard.classList.add(c));
      }

      // Update indicator
      if (filter === 'all') {
        indicator.classList.add('hidden');
      } else {
        indicator.classList.remove('hidden');
        filterLabel.textContent = difficultyLabels[filter] || filter;
      }
    }

    // Click handlers
    statCards.forEach((card) => {
      card.addEventListener('click', () => {
        const filter = card.dataset.filter;
        const currentlyActive = document.querySelector(`#difficulty-stats [data-filter="${filter}"]`);
        const hasRing = currentlyActive && (
          currentlyActive.classList.contains('ring-2')
        );

        if (hasRing) {
          // Toggle off → show all
          applyFilter('all');
        } else {
          applyFilter(filter);
        }
      });
    });

    // Clear filter
    clearBtn.addEventListener('click', () => {
      applyFilter('all');
    });

    // Initialize: show all
    applyFilter('all');
  })();
</script>

<style>
  .truncate {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
