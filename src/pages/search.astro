---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-6">搜索知识点</h1>
    <div class="mb-8">
      <input
        type="search"
        id="search-input"
        placeholder="输入关键词搜索..."
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-500"
      />
    </div>
    <div id="search-results" class="space-y-4">
      <p class="text-gray-500 dark:text-gray-400">Pagefind 搜索将在 Phase 5 集成</p>
    </div>
  </div>
</BaseLayout>
