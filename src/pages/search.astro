---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const nodes = await getCollection('node');
const tags = [...new Set(nodes.flatMap((n) => n.data.tags))].sort();
---

<BaseLayout title="搜索">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">搜索知识点</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6">
      搜索 {nodes.length} 个知识节点 · {tags.length} 个标签
    </p>

    <!-- Pagefind search container (initially empty; JS populates it) -->
    <div id="search" class="pagefind-ui-container mb-8"></div>

    <!-- Tag index -->
    <section class="mt-12">
      <h2 class="text-xl font-bold mb-4">🏷️ 标签索引</h2>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <button
            class="tag-btn px-3 py-1.5 rounded-full text-sm bg-gray-100 dark:bg-gray-800 hover:bg-blue-100 dark:hover:bg-blue-900 transition-colors"
            data-tag={tag}
          >
            #{tag}
            <span class="text-xs text-gray-400 ml-1">
              ({nodes.filter((n) => n.data.tags.includes(tag)).length})
            </span>
          </button>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var searchContainer = document.getElementById('search');
    if (!searchContainer) return;

    function loadCSS(href) {
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = href;
      document.head.appendChild(link);
    }

    function loadScript(src) {
      return new Promise(function (resolve, reject) {
        var s = document.createElement('script');
        s.src = src;
        s.onload = resolve;
        s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    function initPagefind() {
      if (typeof window.PagefindUI === 'undefined') {
        searchContainer.innerHTML =
          '<p class="text-gray-400 text-sm">搜索索引不可用 — 请运行 <code>npm run build</code> 生成索引</p>';
        return;
      }

      try {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          autofocus: true,
          translations: {
            placeholder: '搜索知识点...',
            clear_search: '清除',
            load_more: '加载更多结果',
            search_label: '搜索此站点',
            zero_results: '未找到匹配结果',
            many_results: '找到 [COUNT] 个结果',
            one_result: '找到 1 个结果',
          },
        });
      } catch (e) {
        console.warn('PagefindUI init error:', e);
        searchContainer.innerHTML =
          '<p class="text-gray-400 text-sm">搜索索引不可用</p>';
        return;
      }

      // Auto-search for ?tag=xxx query param
      var params = new URLSearchParams(window.location.search);
      var tagQuery = params.get('tag');
      if (tagQuery) {
        var input = searchContainer.querySelector('input');
        if (input) {
          input.value = tagQuery;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    }

    // Load Pagefind UI assets asynchronously
    loadCSS('/_pagefind/pagefind-ui.css');
    loadScript('/_pagefind/pagefind-ui.js')
      .then(function () {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initPagefind);
        } else {
          initPagefind();
        }
      })
      .catch(function () {
        searchContainer.innerHTML =
          '<p class="text-gray-400 text-sm">搜索索引不可用 — 请运行 <code>npm run build</code> 生成索引</p>';
      });
  })();

  // Tag button click → trigger search
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.tag-btn');
    if (!btn) return;
    var tag = btn.dataset.tag;
    if (!tag) return;

    var input = document.querySelector('#search input');
    if (input) {
      input.value = tag;
      input.dispatchEvent(new Event('input', { bubbles: true }));
      input.focus();
    }
  });
</script>

<style is:global>
  /* ===== Pagefind UI overrides (global — elements are created by JS, no scope attr) ===== */

  .pagefind-ui-container { @apply w-full; }

  /* --- Search input --- */
  .pagefind-ui__search-input {
    @apply h-10 rounded-lg text-sm border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100;
    padding: 0 2.5rem 0 2.75rem !important;
    outline: none !important;
    box-shadow: none !important;
  }
  .pagefind-ui__search-input,
  .pagefind-ui__search-input:focus,
  .pagefind-ui__search-input:active {
    background: #fff !important;
    color: #111827 !important;
  }
  :root.dark .pagefind-ui__search-input,
  :root.dark .pagefind-ui__search-input:focus,
  :root.dark .pagefind-ui__search-input:active {
    background: #1f2937 !important;
    color: #f3f4f6 !important;
    border-color: #4b5563 !important;
  }
  .pagefind-ui__search-input:focus {
    border-color: #60a5fa !important;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15) !important;
  }

  /* --- Search form wrap --- */
  .pagefind-ui__form {
    @apply relative;
  }

  /* --- Clear button (hidden) --- */
  .pagefind-ui__search-clear {
    display: none !important;
  }

  /* --- Results area --- */
  .pagefind-ui__results-area {
    @apply mt-4;
  }

  /* --- Result item (separator line style) --- */
  .pagefind-ui__result {
    @apply py-3;
    border: none !important;
    border-bottom: 1px solid #e5e7eb !important;
    border-radius: 0 !important;
  }
  :root.dark .pagefind-ui__result {
    border-bottom-color: #374151 !important;
  }
  .pagefind-ui__result:last-child {
    border-bottom: none !important;
  }

  /* --- Result title --- */
  .pagefind-ui__result-title {
    font-size: 1.25rem !important; /* text-xl */
    font-weight: 700 !important;    /* bold */
  }
  .pagefind-ui__result-title a {
    @apply no-underline hover:underline;
    color: #2563eb !important;
    font-size: inherit !important;
  }
  :root.dark .pagefind-ui__result-title a {
    color: #60a5fa !important;
  }
  .pagefind-ui__result-nested .pagefind-ui__result-title {
    font-size: 0.9375rem !important; /* = text-base, clearly smaller than main title */
    font-weight: 600 !important;
  }

  /* --- Result excerpt --- */
  .pagefind-ui__result-excerpt {
    @apply text-sm mt-1 leading-relaxed rounded-sm px-0.5;
    color: #4b5563 !important;
  }
  :root.dark .pagefind-ui__result-excerpt {
    color: #9ca3af !important;
  }
  .pagefind-ui__result-excerpt mark {
    @apply text-inherit;
    background: #fef08a !important;
  }
  :root.dark .pagefind-ui__result-excerpt mark {
    background: rgba(113, 63, 18, 0.5) !important;
  }

  /* --- Result title link (inside .pagefind-ui__result-title) --- */
  .pagefind-ui__result-link {
    @apply text-gray-400 dark:text-gray-500 mt-0.5;
  }

  /* --- Result thumbnail --- */
  .pagefind-ui__result-thumb {
    @apply rounded-md overflow-hidden;
  }

  /* --- Nested results (sub results) --- */
  .pagefind-ui__result-nested .pagefind-ui__result {
    @apply border-0 bg-gray-50 dark:bg-gray-900/30 mb-0;
  }

  /* --- Message (status) --- */
  .pagefind-ui__message {
    @apply text-sm text-gray-500 dark:text-gray-400 mb-3;
  }

  /* --- Loading skeleton --- */
  .pagefind-ui__loading {
    @apply text-sm text-gray-400 dark:text-gray-500;
  }

  /* --- Filter panel --- */
  .pagefind-ui__filter-panel {
    @apply bg-gray-50 dark:bg-gray-900 rounded-lg p-3 mb-4;
  }
  .pagefind-ui__filter-label {
    @apply text-sm font-medium text-gray-700 dark:text-gray-300;
  }
  .pagefind-ui__filter-value {
    @apply text-sm text-gray-600 dark:text-gray-400;
  }
  .pagefind-ui__filter-checkbox {
    @apply accent-blue-500;
  }

  /* --- Result tags --- */
  .pagefind-ui__result-tag {
    @apply text-xs px-1.5 py-0.5 rounded bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400;
  }

  /* --- Hidden / suppressed --- */
  .pagefind-ui__hidden { display: none; }
  .pagefind-ui__suppressed { opacity: 0.5; }

  /* --- Drawer (load more) --- */
  .pagefind-ui__drawer {
    @apply mt-2;
  }

  /* --- Button (load more) --- */
  .pagefind-ui__button {
    @apply w-full py-2 px-4 text-sm font-medium rounded-lg border border-gray-200 dark:border-gray-700;
    @apply text-gray-600 dark:text-gray-400 bg-white dark:bg-gray-800;
    @apply hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors;
    cursor: pointer;
  }
</style>
