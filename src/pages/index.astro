---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeTree from '../components/KnowledgeTree.astro';
import { getCollection } from 'astro:content';

const nodes = await getCollection('node');
---

<BaseLayout title="知识树">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <section class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">计算机科学知识树</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        从晶体管到操作系统，从二进制到编译器——自底向上，系统化学习计算机科学
      </p>
    </section>

    <section class="bg-gray-50 dark:bg-gray-900 rounded-xl p-6 min-h-[500px]">
      <KnowledgeTree nodes={nodes.map(n => n.data)} />
    </section>

    <section class="mt-12">
      <h2 class="text-2xl font-bold mb-6">知识领域</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/domain/hardware" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-500 dark:hover:border-blue-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-blue-600 dark:text-blue-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2" />
              <line x1="4" y1="9" x2="2" y2="9" /><line x1="4" y1="15" x2="2" y2="15" />
              <line x1="20" y1="9" x2="22" y2="9" /><line x1="20" y1="15" x2="22" y2="15" />
              <line x1="9" y1="4" x2="9" y2="2" /><line x1="15" y1="4" x2="15" y2="2" />
              <line x1="9" y1="20" x2="9" y2="22" /><line x1="15" y1="20" x2="15" y2="22" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">硬件基础</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">逻辑门、触发器、寄存器、ALU</p>
            </div>
          </div>
        </a>
        <a href="/domain/assembly" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-emerald-500 dark:hover:border-emerald-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-emerald-600 dark:text-emerald-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
              <line x1="10" y1="4" x2="14" y2="20" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">汇编语言</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">指令集、寻址模式、调用约定</p>
            </div>
          </div>
        </a>
        <a href="/domain/os" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-500 dark:hover:border-purple-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-purple-600 dark:text-purple-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">操作系统</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">进程管理、内存管理、文件系统</p>
            </div>
          </div>
        </a>
        <a href="/domain/compilers" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-orange-600 dark:text-orange-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5" />
              <line x1="12" y1="22" x2="12" y2="15.5" />
              <polyline points="22 8.5 12 15.5 2 8.5" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">编译器</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">词法分析、语法分析、代码生成</p>
            </div>
          </div>
        </a>
        <a href="/domain/networking" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-cyan-500 dark:hover:border-cyan-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-cyan-600 dark:text-cyan-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <ellipse cx="12" cy="12" rx="4" ry="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">计算机网络</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">TCP/IP、HTTP、路由协议</p>
            </div>
          </div>
        </a>
        <a href="/domain/databases" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-rose-500 dark:hover:border-rose-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-rose-600 dark:text-rose-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <ellipse cx="12" cy="5" rx="9" ry="3" />
              <path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5" />
              <path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">数据库</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">SQL、索引、事务、B+树</p>
            </div>
          </div>
        </a>
        <a href="/domain/algorithms" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-amber-500 dark:hover:border-amber-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-amber-600 dark:text-amber-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="12" width="4" height="9" />
              <rect x="10" y="7" width="4" height="14" />
              <rect x="17" y="3" width="4" height="18" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">数据结构与算法</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">排序、图、动态规划</p>
            </div>
          </div>
        </a>
        <a href="/domain/programming-languages" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-pink-500 dark:hover:border-pink-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-pink-600 dark:text-pink-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5" />
              <line x1="12" y1="19" x2="20" y2="19" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">编程语言理论</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">类型系统、范式、λ演算</p>
            </div>
          </div>
        </a>
        <a href="/domain/software-eng" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-gray-500 dark:hover:border-gray-400 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-gray-600 dark:text-gray-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">软件工程</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">设计模式、测试、CI/CD</p>
            </div>
          </div>
        </a>
        <a href="/domain/cryptography" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-yellow-500 dark:hover:border-yellow-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-yellow-600 dark:text-yellow-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">密码学</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">对称加密、公钥加密、数字签名</p>
            </div>
          </div>
        </a>
        <a href="/domain/computer-graphics" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-indigo-500 dark:hover:border-indigo-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-indigo-600 dark:text-indigo-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
              <rect x="6" y="7" width="3" height="3" />
              <rect x="11" y="7" width="3" height="3" />
              <rect x="16" y="7" width="3" height="3" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">计算机图形学</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">渲染管线、着色、纹理</p>
            </div>
          </div>
        </a>
        <a href="/domain/machine-learning" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-teal-500 dark:hover:border-teal-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-teal-600 dark:text-teal-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="5" r="3" />
              <circle cx="5" cy="19" r="3" />
              <circle cx="19" cy="19" r="3" />
              <line x1="9.5" y1="7.5" x2="6.5" y2="16.5" />
              <line x1="14.5" y1="7.5" x2="17.5" y2="16.5" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">机器学习</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">神经网络、决策树、强化学习</p>
            </div>
          </div>
        </a>
        <a href="/domain/cybersecurity" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-red-500 dark:hover:border-red-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-red-600 dark:text-red-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">网络安全</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">渗透测试、防火墙、零信任</p>
            </div>
          </div>
        </a>
        <a href="/domain/distributed-systems" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-sky-500 dark:hover:border-sky-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-sky-600 dark:text-sky-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="5" cy="12" r="2" />
              <circle cx="12" cy="12" r="2" />
              <circle cx="19" cy="12" r="2" />
              <line x1="7" y1="12" x2="10" y2="12" />
              <line x1="14" y1="12" x2="17" y2="12" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">分布式系统</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">共识算法、CAP理论、RPC</p>
            </div>
          </div>
        </a>
        <a href="/domain/quantum-computing" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-violet-500 dark:hover:border-violet-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-violet-600 dark:text-violet-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <ellipse cx="12" cy="12" rx="4" ry="10" />
              <ellipse cx="12" cy="12" rx="10" ry="4" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">量子计算</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">量子比特、量子门、量子纠错</p>
            </div>
          </div>
        </a>
        <a href="/domain/web3-blockchain" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-orange-500 dark:hover:border-orange-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-orange-600 dark:text-orange-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 7 12 13 20 7" />
              <polyline points="4 17 12 11 20 17" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">Web3与区块链</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">去中心化、智能合约、共识机制</p>
            </div>
          </div>
        </a>
        <a href="/domain/formal-methods" class="domain-card p-4 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-lime-500 dark:hover:border-lime-500 transition-colors">
          <div class="flex items-start gap-3">
            <svg class="w-6 h-6 mt-0.5 text-lime-600 dark:text-lime-400 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg>
            <div>
              <h3 class="font-bold text-lg mb-1">形式化方法</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400">模型检验、定理证明、霍尔逻辑</p>
            </div>
          </div>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
